// npm i express bcrypt crypto
const express = require("express");
const crypto = require("crypto");
const bcrypt = require("bcrypt");
const app = express();
app.use(express.json());

const otpStore = new Map(); // phone -> { hash, expiresAt, attempts }

function generateOtp() {
  return (Math.floor(100000 + Math.random() * 900000)).toString();
}

// request OTP (TEST MODE supported)
app.post("/otp/request", async (req, res) => {
  const { phone, testMode } = req.body;

  const otp = generateOtp();
  const hash = await bcrypt.hash(otp, 10);

  otpStore.set(phone, {
    hash,
    expiresAt: Date.now() + 60_000,
    attempts: 0
  });

  // In test mode, DON'T send SMS; return OTP for QA only
  if (testMode === true) {
    return res.json({ message: "OTP generated (test mode)", otp });
  }

  // In production, send via SMS API (Twilio/Fast2SMS)
  // sendSms(phone, otp);

  res.json({ message: "OTP sent" });
});

// verify OTP
app.post("/otp/verify", async (req, res) => {
  const { phone, otp } = req.body;
  const record = otpStore.get(phone);

  if (!record) return res.status(400).send("No OTP");
  if (Date.now() > record.expiresAt) return res.status(400).send("Expired");

  record.attempts++;
  if (record.attempts > 5) return res.status(429).send("Too many attempts");

  const ok = await bcrypt.compare(otp, record.hash);
  if (!ok) return res.status(401).send("Invalid OTP");

  otpStore.delete(phone);
  res.send("Verified ✅");
});

app.listen(3000, () => console.log("Server on 3000"));